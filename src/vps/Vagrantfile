Vagrant.configure('2') do |config|

    if ARGV[1] == 'travis'
        ARGV.delete_at(1)
        travis = true
    else
        travis = false
    end

    config.vm.provider :virtualbox do |virtualbox, override|
        virtualbox.customize ["modifyvm", :id, "--natdnshostresolver1", "on"]
		virtualbox.customize ["modifyvm", :id, "--graphicscontroller", "vmsvga"]
		#virtualbox.customize ["modifyvm", :id, "--nested-hw-virt", "on"]
		virtualbox.customize ["modifyvm", :id, "--nestedpaging", "on"]
		virtualbox.name		= "VPS_DEV"
		virtualbox.memory	= "4096"
		virtualbox.cpus   	= "3"
        #override.vm.box = 'Ubuntu 12.10 x64 Server'
        #override.vm.box_url = 'http://goo.gl/wxdwM'
    end

    if travis == false
        config.vm.define :VPS_CORE do |vps_core|
            vps_core.vm.define "VPS_CORE"
            vps_core.vm.box = "ubuntu/focal64"
            #config.vm.box_version = "0.4.4"
            #config.vm.hostname  = "vps"
            #config.ssh.username = "neo"
            #config.ssh.password = "neoricalex"
            #config.disksize.size = '100GB'
        end

        #config.vm.define :normal2 do |normal2|
        #    normal2.vm.hostname = 'normal2'
            #normal2.vm.network :private_network, ip: "192.168.1.2"
        #end
    end
    if travis == true
        config.vm.define :travis1 do |travis1|
            travis1.vm.hostname = 'travis1'
            #travis1.vm.network :private_network, ip: "192.168.1.3"
        end

        #config.vm.define :travis2 do |travis2|
        #    travis2.vm.hostname = 'travis2'
        #    #travis2.vm.network :private_network, ip: "192.168.1.4"
        #end
    end
end
#!/bin/bash
#set -x

instalar_requerimentos(){
    echo "Atualizar repositórios e instalar requerimentos..."
    sudo apt update
    sudo apt install -y \
        build-essential \
        autoconf \
        make \
        tmux \
        git

    versao_vagrant_atual="2.2.9"
    if ! command -v vagrant &> /dev/null   
    then
        sudo apt install virtualbox -y 
        curl -O https://releases.hashicorp.com/vagrant/${versao_vagrant_atual}/vagrant_${versao_vagrant_atual}_x86_64.deb
        sudo apt install ./vagrant_${versao_vagrant_atual}_x86_64.deb
        rm ./vagrant_${versao_vagrant_atual}_x86_64.deb
    fi

    versao_vagrant_instalada=$(vagrant --version | awk 'NR==1{print $2; exit}')
    if [ -z "$versao_vagrant_instalada" ]
    then
        versao_vagrant_instalada=$versao_vagrant_atual
    fi

    if [ "$versao_vagrant_atual" != "$versao_vagrant_instalada" ]
    then
        echo "Atualizando o Vagrant..."
        sudo apt update
        sudo apt remove vagrant -y
        curl -O https://releases.hashicorp.com/vagrant/${versao_vagrant_atual}/vagrant_${versao_vagrant_atual}_x86_64.deb
        sudo apt install ./vagrant_${versao_vagrant_atual}_x86_64.deb
        rm ./vagrant_${versao_vagrant_atual}_x86_64.deb
    fi

    if ! vagrant plugin list | grep -q "vagrant-disksize"
    then
        echo "Instalando o plugin vagrant-disksize..."
        vagrant plugin install vagrant-disksize
    fi

}

instalar_requerimentos

if [ ! -f "src/neoricalex.o" ] ; then
    autoreconf --install
    ./configure
    make
    #make distcheck
fi

src/neoricalex
